{
  "name": "hk-cantonese-copywriter",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"cd client && npm run dev\" \"cd server && npm run dev\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:local": "concurrently -n client,server,model -c blue,green,yellow \"cd client && npm run dev\" \"cd server && npm run dev\" \"python server_4b_api.py\"",
    "install:all": "npm ci",
    "test": "npm run test:client && npm run test:server",
    "test:client": "cd client && npx vitest run",
    "test:server": "cd server && npm test",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "cd client && npx tsc --noEmit",
    "typecheck:server": "cd server && npx tsc --noEmit",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "audit:prod": "npm audit --omit=dev",
    "audit:all": "npm audit",
    "test:e2e:smoke": "playwright test --config=playwright.config.mjs",
    "test:e2e:smoke:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/e2e-public-smoke.ps1",
    "test:e2e:smoke:win:twice": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/e2e-public-smoke.ps1 -Twice",
    "test:e2e:workbench:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/e2e-workbench-shell.ps1",
    "test:e2e:workbench:win:twice": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/e2e-workbench-shell.ps1 -Twice",
    "dev:client:e2e": "cd client && npx vite --config vite.e2e.config.ts --host 127.0.0.1 --port 5184 --strictPort",
    "verify": "npm run test && npm run typecheck && npm run build && npm run audit:prod && npm run audit:all"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "concurrently": "^9.2.4",
    "supabase": "^2.109.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "body-parser": "2.3.0",
    "form-data": "4.0.6",
    "shell-quote": "1.10.0"
  }
}
