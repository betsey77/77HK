# ============================================================
# 77港话通社媒文案器 — 环境变量契约（全部留空）
# 复制为 .env / server/.env / client/.env 后按需填写。
# 本文件不得包含真实密钥、token、私钥或项目 URL 中的 secret。
# ============================================================

# ── Model / generation engines ───────────────────────────────
# Self-hosted Cantonese 4B model (PRIMARY — local dev only)
CANTONESE_API_URL=
CANTONESE_API_KEY=

# Featherless.ai API Key (PRIMARY cloud option)
FEATHERLESS_API_KEY=

# DeepSeek API Key (FALLBACK + AUDIT)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

# HuggingFace (optional CantoneseLLMChat)
HF_API_KEY=
HF_MODEL=

# OpenRouter (optional Qwen Cantonese enhancement)
OPENROUTER_API_KEY=

# ── Optional integrations ────────────────────────────────────
# YouTube Data API v3 (HK trending + search)
YOUTUBE_API_KEY=

# Meta Access Token (competitor ad search fallback)
META_ACCESS_TOKEN=

# HTTP(S) proxy for blocked outbound APIs (optional)
HTTPS_PROXY=
HTTP_PROXY=
https_proxy=
http_proxy=

# ── Supabase Auth + DB (Slice B+) ────────────────────────────
# Browser-visible (client). Never put service/secret keys here.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional client API base when frontend/backend are on different origins.
# Example shape only (leave empty locally): https://your-api-host.example
# Do not put secrets, private keys, or service-role tokens in any VITE_ variable.
VITE_API_BASE_URL=

# Server-side Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Trusted secret for BFF: quota ledger, job transitions, payments.
# NEVER expose via VITE_ prefix, client bundle, logs, or evidence.
SUPABASE_SECRET_KEY=
# Optional file pointer (raw value or SUPABASE_SECRET_KEY=... line).
# Direct SUPABASE_SECRET_KEY wins over file.
SUPABASE_SECRET_KEY_FILE=

# ── Server ───────────────────────────────────────────────────
PORT=

# Comma-separated exact browser Origins allowed by CORS.
# Empty → local defaults only: http://localhost:5173, http://127.0.0.1:5173
# Production/Preview must list the real frontend origin(s). No *.vercel.app wildcard.
# Server-to-server / Alipay notify (no Origin header) remain allowed.
ALLOWED_ORIGINS=

# ── Server酱 Turbo (Slice H1 feedback notify, best-effort) ───
SERVERCHAN_SENDKEY=
SERVERCHAN_SENDKEY_FILE=

# ── Payment (Slice E / F1) ───────────────────────────────────
# mock (default) | alipay_sandbox
# "production" remains forbidden until a separate production adapter
# and user authorization exist.
PAYMENT_MODE=

# Alipay sandbox credentials (required only when PAYMENT_MODE=alipay_sandbox)
ALIPAY_APP_ID=
ALIPAY_SELLER_ID=

# Prefer file pointers over inline PEM values in shell history.
ALIPAY_PRIVATE_KEY=
ALIPAY_PRIVATE_KEY_FILE=
ALIPAY_PUBLIC_KEY=
ALIPAY_PUBLIC_KEY_FILE=

# Split hosting: frontend origin for return URL, API origin for notify URL.
# Example shapes only — leave empty for local 5173/3001 fallbacks.
APP_FRONTEND_URL=
APP_API_URL=

# Legacy single public URL used as fallback for both return and notify.
APP_PUBLIC_URL=

# Explicit full URL overrides (highest priority)
ALIPAY_RETURN_URL=
ALIPAY_NOTIFY_URL=
