# Self-hosted Cantonese 4B model (PRIMARY — local dev only)
# Start the model API: python server_4b_api.py
# Set this to the model server URL (typically http://localhost:8000)
# Leave empty for production (Netlify) — DeepSeek will be the primary engine
CANTONESE_API_URL=

# Featherless.ai API Key (PRIMARY cloud option — CantoneseLLMChat-v1.0-32B)
# Without CANTONESE_API_URL or this, the app falls back to DeepSeek.
# Get one at https://featherless.ai
FEATHERLESS_API_KEY=

# DeepSeek API Key (FALLBACK + AUDIT — used for audit scoring and as fallback generator)
DEEPSEEK_API_KEY=

# HuggingFace API Key (optional, for CantoneseLLMChat — currently blocked in this environment)
HF_API_KEY=

# OpenRouter API Key (optional, for Qwen 3.5 Cantonese enhancement)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# YouTube Data API v3 (optional, for HK trending + search)
# Without this, YouTube services return empty arrays gracefully.
# Get one at https://console.cloud.google.com/ → YouTube Data API v3
YOUTUBE_API_KEY=

# Meta Access Token (optional, for competitor ad search fallback)
# Without this, competitor search falls back to Python script only.
# Get one at https://developers.facebook.com/
META_ACCESS_TOKEN=

# ============================================================
# Supabase (Slice B+)
# Get these from: Supabase Dashboard > Project Settings > API
# ============================================================
# SUPABASE_URL=https://<your-project-id>.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ============================================================
# Server-side trusted secret (Slice C2a+)
# Required for trusted BFF operations: quota ledger, job state transitions.
# NEVER expose this key in client code or VITE_ prefixed env vars.
# ============================================================
# SUPABASE_SECRET_KEY=sb_secret_...
# Optional alternative for local/server environments that keep the secret in a
# separate file. The file may contain either the raw value or one line in the
# form SUPABASE_SECRET_KEY=sb_secret_.... Direct SUPABASE_SECRET_KEY wins.
# SUPABASE_SECRET_KEY_FILE=D:\path\to\SUPABASE_SECRET_KEY.txt

# ============================================================
# Server酱 Turbo — 微信通知（Slice H1: 管理员反馈通知）
# 支持直接 SERVERCHAN_SENDKEY=SCU... 或文件指针
# 文件内容格式：raw key 或 SERVERCHAN_SENDKEY=SCU...
# 通知是 best-effort：反馈先持久化，通知失败不丢失反馈
# ============================================================
# SERVERCHAN_SENDKEY=SCU...
# SERVERCHAN_SENDKEY_FILE=D:\path\to\sendkey.txt

# Server port
PORT=3001
